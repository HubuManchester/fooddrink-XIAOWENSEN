<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodApp.MainPage"
             Title="美食助手">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            <Label Text="🥗 食物与饮品助手"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="输入你想吃的食物："
                   FontSize="16" />

            <Entry x:Name="FoodEntry"
                   Placeholder="例如：披萨, 沙拉, 咖啡..."
                   FontSize="16" />

            <Button x:Name="RecommendButton"
                    Text="推荐食谱 / 搭配"
                    Clicked="OnRecommendClicked"
                    BackgroundColor="Green"
                    TextColor="White" />

            <Label x:Name="ResultLabel"
                   FontSize="16"
                   LineBreakMode="WordWrap" />

            <!-- 硬件功能按钮 -->
            <Button Text="🔊 语音读出推荐"
                    Clicked="OnSpeakClicked"
                    BackgroundColor="Blue"
                    TextColor="White" />

            <Button Text="📍 查找附近餐厅"
                    Clicked="OnNearbyClicked"
                    BackgroundColor="Orange"
                    TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>